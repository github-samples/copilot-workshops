{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@partials/*": ["./src/types/_partials/*", "./src/content/docs/_partials/*"]
    },
    "plugins": [
      { "name": "@mdx-js/typescript-plugin" }
    ]
  }
}
